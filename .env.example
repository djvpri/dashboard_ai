GATEWAY_URL=http://localhost:18789
GATEWAY_TOKEN=

# Password login dashboard — WAJIB diisi, tidak ada default.
DASHBOARD_PASSWORD=

# Secret untuk menandatangani session token (JWT) — WAJIB diisi, buat
# sendiri (mis. `openssl rand -hex 32`), TERPISAH dari DASHBOARD_PASSWORD.
SESSION_SECRET=

# Backend agent Hermes (opsional) — API server hermes-agent.
# Aktifkan di service hermes-agent: API_SERVER_ENABLED=true + API_SERVER_KEY.
# Tanpa ini, agent Hermes menampilkan pesan belum-dikonfigurasi (Ojamet tetap jalan).
HERMES_API_URL=
HERMES_API_KEY=

# Riwayat chat & kustomisasi agent tersinkron lintas browser (Postgres).
# Jalankan migrations/001_history.sql sekali di database ini.
DATABASE_URL=
